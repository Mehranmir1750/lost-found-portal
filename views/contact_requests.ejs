<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Requests - IUST Found & Lost</title>
    <link rel="stylesheet" href="/css/contact_requests.css">
</head>
<body>
    
    <%- include("partials/navbar") %>

    <div class="page">
        <div class="header-section">
            <h1>Contact Requests 📬</h1>
            <p>Manage requests from people interested in your items</p>
        </div>

        <div class="stats-bar">
            <div class="stat-card">
                <div class="stat-label">Total Requests</div>
                <div class="stat-value" id="totalRequests">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Pending</div>
                <div class="stat-value pending" id="pendingRequests">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Approved</div>
                <div class="stat-value approved" id="approvedRequests">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Rejected</div>
                <div class="stat-value rejected" id="rejectedRequests">0</div>
            </div>
        </div>

        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterRequests('all')">All Requests</button>
            <button class="filter-tab" onclick="filterRequests('pending')">Pending</button>
            <button class="filter-tab" onclick="filterRequests('approved')">Approved</button>
            <button class="filter-tab" onclick="filterRequests('rejected')">Rejected</button>
        </div>

        <div class="requests-grid" id="requestsGrid">
            <% if (requests.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-state-icon">📭</div>
                    <div class="empty-state-title">No contact requests yet</div>
                    <div class="empty-state-text">When someone wants to contact you about your items, their requests will appear here.</div>
                </div>
            <% } %>

            <% requests.forEach(req => { %>
                <div class="request-card <%= req.status %>" data-status="<%= req.status %>">
                    <div class="request-header">
                        <div class="request-title">
                            <span class="item-type-badge <%= req.item_type ? req.item_type.toLowerCase() : 'lost' %>">
                                <%= req.item_type || 'LOST' %>
                            </span>
                            <div class="item-name"><%= req.item_name %></div>
                        </div>
                        <div class="status-badge <%= req.status %>">
                            <%= req.status.toUpperCase() %>
                        </div>
                    </div>

                    <div class="requester-info">
                        <div class="requester-avatar">
                            <%= req.first_name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="requester-details">
                            <div class="requester-name">
                                <%= req.first_name %> <%= req.last_name %>
                            </div>
                            <div class="requester-meta">
                                <% if (req.status === 'approved' && req.email) { %>
                                    <div class="contact-info">
                                        <span class="contact-badge">📧 <%= req.email %></span>
                                        <% if (req.phone) { %>
                                            <span class="contact-badge">📱 <%= req.phone %></span>
                                        <% } %>
                                    </div>
                                <% } else { %>
                                    <span>Requested contact information</span>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <% if (req.message) { %>
                        <div class="message-section">
                            <div class="message-label">Message</div>
                            <div class="message-content">"<%= req.message %>"</div>
                        </div>
                    <% } %>

                    <div class="request-footer">
                        <div class="request-date">
                            🕒 <%= new Date(req.created_at).toLocaleDateString('en-US', { 
                                year: 'numeric', 
                                month: 'long', 
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            }) %>
                        </div>

                        <div class="action-buttons">
                            <% if (req.status === 'pending') { %>
                                <button class="btn btn-approve" onclick="approveRequest(<%= req.id %>, this)">
                                    <span>✓</span>
                                    <span>Approve</span>
                                </button>
                                <button class="btn btn-reject" onclick="rejectRequest(<%= req.id %>, this)">
                                    <span>✗</span>
                                    <span>Reject</span>
                                </button>
                            <% } %>
                            <button class="btn btn-view" onclick="window.location.href='/items/<%= req.item_id %>'">
                                <span>👁️</span>
                                <span>View Item</span>
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="toast" id="toast"></div>

     <script src="/js/contact_requests.js"></script>
</body>
</html>