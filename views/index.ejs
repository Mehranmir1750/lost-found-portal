<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'IUST Found and Lost' %></title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>

    <div class="particles"></div>

    <!-- ═══════════════════
         NAVBAR
    ════════════════════ -->
    <nav class="navbar">

        <img src="/images/logo.jpeg" alt="IUST Lost & Found" />

        <div class="logo">IUST Found & Lost Portal</div>

        <!--
            DESKTOP: nav-links + nav-auth visible, hamburger hidden
            MOBILE:  nav-links + nav-auth hidden, hamburger visible
                     clicking hamburger shows mobile-dropdown
        -->

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="#how">How It Works</a>
        </div>

        <div class="nav-auth">
            <a href="/register"    class="btn btn-register">Register</a>
            <a href="/login"       class="btn btn-login">Login</a>
            <a href="/admin/login" class="btn btn-admin">Admin</a>
        </div>

        <!-- Hamburger: mobile only -->
        <button class="hamburger" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </button>

    </nav>

    <!-- Mobile dropdown — sits below navbar, full width -->
    <div class="mobile-dropdown" id="mobileDropdown">
        <a href="/">Home</a>
        <a href="#how">How It Works</a>
        <div class="dropdown-divider"></div>
        <a href="/register"    class="dropdown-btn btn-register">Register</a>
        <a href="/login"       class="dropdown-btn btn-login">Login</a>
        <a href="/admin/login" class="dropdown-btn btn-admin">Admin</a>
    </div>

    <!-- ═══════════════════
         HERO
    ════════════════════ -->
    <section class="hero">
        <div class="hero-content">
            <img src="/images/logo.jpeg" alt="IUST Lost & Found" />
            <h1>Lost Something?<br>Found Something?</h1>
            <p class="hero-sub">IUST's Trusted Lost & Found Platform</p>
            <p class="hero-desc">
                Connect with your community to reunite lost items with their rightful owners.
                Whether you've lost your phone, wallet, or found something — we're here to help.
            </p>
            <div class="hero-btns">
                <a href="/login" class="btn btn-lost">📢 I Lost Something</a>
                <a href="/login" class="btn btn-found">✨ I Found Something</a>
                <a href="/login" class="btn btn-dark">🔍 Search Items</a>
            </div>
        </div>
    </section>

    <!-- ═══════════════════
         RECENT ITEMS
    ════════════════════ -->
    <section class="items-section">

        <div class="items-header">
            <h2>Recent Lost & Found Items</h2>
            <a href="/login">View All →</a>
        </div>

        <% if (items && items.length === 0) { %>

        <div class="empty-state">
            <span>📭</span>
            <p>No items posted yet. Be the first!</p>
            <a href="/login" class="btn btn-login">Post an Item</a>
        </div>

        <% } else { %>

        <div class="filter-tabs">
            <button class="tab active" data-filter="all">All Items</button>
            <button class="tab" data-filter="lost">Lost</button>
            <button class="tab" data-filter="found">Found</button>
        </div>

        <div class="items-grid">
            <% items.forEach(item => { %>
            <div class="item-card" data-type="<%= item.type.toLowerCase() %>">

                <div class="card-img">
                    <img src="<%= item.image %>" alt="<%= item.item_name %>">
                    <span class="type-badge <%= item.type.toLowerCase() %>">
                        <%= item.type === 'lost' ? '📢' : '✨' %> <%= item.type %>
                    </span>
                </div>

                <div class="card-body">
                    <div class="card-name"><%= item.item_name %></div>
                    <div class="card-loc">📍 <%= item.location %></div>
                    <div class="item-landmark"> <%= item.landmark %> </div>
                    <% if (item.description) { %>
                    <div class="card-desc">
                        <%= item.description.substring(0, 90) %><%= item.description.length > 90 ? '...' : '' %>
                    </div>
                    <% } %>
                </div>

                <div class="card-footer">
                    <div class="card-user">
                        <div class="avatar">
                            <%= item.first_name ? item.first_name.charAt(0).toUpperCase() : '?' %>
                        </div>
                        <span><%= item.first_name %> <%= item.last_name %></span>
                    </div>
                    <a href="/items/<%= item.item_id %>" class="btn-view">View</a>
                </div>

            </div>
            <% }) %>
        </div>

        <% } %>
    </section>

    <!-- ═══════════════════
         HOW IT WORKS
    ════════════════════ -->
    <section class="how-section" id="how">
        <h2>How It Works</h2>
        <p class="how-sub">Simple steps to reunite with your belongings</p>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-num">1</div>
                <h3>Post Your Item</h3>
                <p>Create a post with photos, description and location.</p>
            </div>
            <div class="step-card">
                <div class="step-num">2</div>
                <h3>Search & Match</h3>
                <p>Browse listings or search to find matching items.</p>
            </div>
            <div class="step-card">
                <div class="step-num">3</div>
                <h3>Connect & Recover</h3>
                <p>Contact the owner and arrange a safe meetup.</p>
            </div>
        </div>
    </section>

    <!-- ═══════════════════
         FOOTER
    ════════════════════ -->
    <footer class="footer">
        <p>© <%= new Date().getFullYear() %> IUST Found and Lost. Helping reunite IUST, one item at a time. 💙</p>
    </footer>

    <script src="/js/index.js"></script>

</body>
</html>
