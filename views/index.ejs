    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content">
            <h1 class="hero-title">Lost Something? Found Something?</h1>
            <p class="hero-subtitle">IUST's Trusted Lost & Found Platform</p>
            <p class="hero-description">
                Connect with your community to reunite lost items with their rightful owners. Whether you've lost your phone, 
                wallet, jewelry, or found something that belongs to someone else - we're here to help bridge the gap.
            </p>
            <div class="hero-buttons">
                <a href="/search" class="btn btn-lost btn-large">📢 I Lost Something</a>
                <a href="/search" class="btn btn-found btn-large">✨ I Found Something</a>
                <a href="/search" class="btn btn-register btn-large">🔍 Search Items</a>
            </div>
        </div>
    </section>








    <!-- Recent Items Section -->
    <section class="recent-items" id="recent">
        <div class="recent-items-header">
            <h2 class="section-title">Recent Lost & Found Items</h2>
            <a href="/search" class="view-all-link">View All Items →</a>
        </div>
        
        <% if (items && items.length === 0) { %>
        <div class="no-items">
            <div class="no-items-icon">📭</div>
            <p class="no-items-text">No items posted yet.</p>
            <p class="no-items-subtext">Be the first to post an item and help someone!</p>
            <div class="no-items-buttons">
                <a href="/post/lost" class="btn btn-lost">Post Lost Item</a>
                <a href="/post/found" class="btn btn-found">Post Found Item</a>
            </div>
        </div>
        <% } else { %>
        <div class="items-filter-tabs">
            <button class="filter-tab active" onclick="filterItems('all')">All Items</button>
            <button class="filter-tab" onclick="filterItems('lost')">Lost</button>
            <button class="filter-tab" onclick="filterItems('found')">Found</button>
        </div>
        
        <div class="items-list">
            <% items.forEach(item => { %>
            <div class="item-card" data-type="<%= item.type.toLowerCase() %>">
                <div class="item-card-header">
                    <span class="item-badge <%= item.type.toLowerCase() %>">
                        <%= item.type === 'lost' ? '📢' : '✨' %> <%= item.type %>
                    </span>
                    <span class="item-date">
                        <%= new Date(item.created_at || Date.now()).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                    </span>
                </div>
                
                <div class="item-card-body">
                    <!-- <img src="<% item.photo %>"> -->
                     <img src="<%= item.image %>" alt="Item Image">
                    <h3 class="item-title"><%= item.item_name %></h3>
                    
                    <div class="item-details">
                        <div class="item-detail-row">
                            <span class="detail-icon">📍</span>
                            <span class="detail-text"><%= item.location %></span>
                        </div>
                        
                        <% if (item.category) { %>
                        <div class="item-detail-row">
                            <span class="detail-icon">🏷️</span>
                            <span class="detail-text"><%= item.category %></span>
                        </div>
                        <% } %>
                        
                        <% if (item.description) { %>
                        <div class="item-description">
                            <p><%= item.description.substring(0, 100) %><%= item.description.length > 100 ? '...' : '' %></p>
                        </div>
                        <% } %>
                    </div>
                </div>
                
                <div class="item-card-footer">
                    <div class="item-user">
                        <div class="user-avatar">
                            <%= item.first_name ? item.first_name.charAt(0).toUpperCase() : '?' %>
                        </div>
                        <span class="user-name"><%= item.first_name %> <%= item.last_name %></span>
                    </div>
                    <!-- <a href="/items/<%= item.id %>" class="btn-view-details">View Details</a> -->
                     <a href="/login/<%= item.id %>" class="btn-view-details"> View Details</a>

                </div>
            </div>
            <% }) %>
        </div>
        <% } %>
    </section>










    <!-- Features Section -->
    <section class="features" id="features">
        <h2 class="section-title">Why Choose Us?</h2>
        <p class="section-subtitle">We provide a reliable and transparent platform that connects people
             with their lost belongings quickly and securely. Our system is designed to be easy to use, 
             ensuring that anyone can report or find lost items without confusion. With accurate listings 
             and a user-friendly interface, we help reunite people with what matters most.</p>
    </section>

    

    <!-- How It Works Section -->
    <section class="how-it-works" id="how">
        <h2 class="section-title">How It Works</h2>
        <p class="section-subtitle">Simple steps to reunite with your belongings</p>
        <div class="steps-container">
            <% 
            const steps = [
                { number: 1, title: 'Post Your Item', description: 'Create a detailed post with photos, description, location, and date. Choose whether you lost or found something.' },
                { number: 2, title: 'Search & Match', description: 'Browse through listings or use our smart search to find items matching your description. Get instant alerts for new matches.' },
                { number: 3, title: 'Connect & Recover', description: 'Connect securely through our platform, verify ownership, and arrange a safe meetup to return the item.' }
            ];
            %>
            <% steps.forEach(function(step) { %>
            <div class="step-card">
                <div class="step-number"><%= step.number %></div>
                <h3 class="step-title"><%= step.title %></h3>
                <p class="step-description"><%= step.description %></p>
            </div>
            <% }); %>
        </div>
    </section>

