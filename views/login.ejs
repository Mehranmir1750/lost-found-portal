<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - IUST Found & Lost</title>
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <!-- Floating Particles -->

      <nav class="navbar">
        <div class="logo">IUST Found &amp; Lost Portal</div>
        <div class="mobile-menu" onclick="toggleMenu()">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="nav-links" id="navLinks">
            <a href="/">Back</a>
        </div>
    </nav>

    
    <div class="particles" id="particles"></div>

    <div class="login-wrapper">
        <!-- Left Side Info -->
        <div class="login-info">
            <div class="logo">IUST Found & Lost</div>
            <h1>Welcome Back!</h1>
            <p>Sign in to access your account and continue helping reunite lost items with their owners across IUST.</p>
            
            <div class="mission-statement">
                <div class="mission-icon">💙</div>
                <blockquote class="mission-quote">
                    "Our mission is to reunite every lost item with its rightful owner through the power of community and technology. We believe in building trust, fostering connections, and bringing hope to those who have lost something precious."
                </blockquote>
                <div class="mission-signature">
                    <div class="signature-line"></div>
                    <p class="mission-author">IUST Found & Lost Team</p>
                </div>
            </div>
        </div>

        <!-- Login Form -->
        <div class="login-container">
            <h2>Login</h2>
            <p class="subtitle">Enter your credentials to continue</p>

            <div class="error-message" id="errorMessage"></div>
            <div class="success-message" id="successMessage"></div>

            <form action="/login" method="POST" id="loginForm">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="your.email@example.com" 
                        required
                    >
                    <span class="input-icon">📧</span>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        placeholder="Enter your password" 
                        required
                    >
                    <span class="password-toggle" onclick="togglePassword()">👁️</span>
                </div>

                <div class="form-options">
                    <div class="remember-me">
                        <input type="checkbox" id="remember" name="remember">
                        <label for="remember">Remember me</label>
                    </div>
                    <a href="/forgot-password" class="forgot-password">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-submit">Login</button>
            </form>

            <div class="register-link">
                Don't have an account? <a href="/register">Register here</a>
            </div>
        </div>
    </div>

     <script src="/js/login.js"></script>
</body>
</html>